+def _pwd_flags_direct_libs(args):
+    """Prefix execroot-relative direct static/object file arguments with ${pwd}.
+
+    Handles bare .a and .o file path arguments passed directly to the linker,
+    without any associated flag (e.g. a direct path to libclang_rt.builtins.a).
+    """
+    res = []
+    for arg in args:
+        if not arg.startswith("-") and not paths.is_absolute(arg) and (arg.endswith(".a") or arg.endswith(".o")):
+            res.append("${{pwd}}/{}".format(arg))
+        else:
+            res.append(arg)
+    return res
+
